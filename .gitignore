# Vendored offline binaries are large and platform-specific; restored by
# offline-sdk/node/README.md's vendoring script, not committed as blobs.
offline-sdk/node/*/
offline-sdk/ai-models/*.gguf
offline-sdk/speech-models/**/*.bin
offline-sdk/speech-models/**/*.onnx
offline-sdk/build-tools/*/
offline-sdk/ai-models/fastembed-cache/
offline-sdk/ai-models/whisper-models/
offline-sdk/ai-models/piper-voices/*.onnx
offline-sdk/ai-models/piper-voices/*.onnx.json

# Stray/duplicate SDK copy found inside the repo (Stage 2 moved Android/Flutter
# SDKs to D:\dev-sdks outside the repo specifically to avoid path-with-spaces
# issues; this directory is leftover from before that and should not be
# committed regardless of why it reappeared).
offline-sdk/dev-sdks/

# Stage 37: bundled CJK font. Large vendored binary, restored per
# apps/desktop/src/fonts/README.md rather than committed. The OFL license text
# beside it IS committed -- it must accompany any redistribution of the font.
apps/desktop/src/fonts/*.ttf
apps/desktop/src/fonts/*.otf
apps/desktop/src/fonts/*.woff2

{
  "name": "@englishclass/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.json && electron .",
    "build": "tsc -p tsconfig.json",
    "package": "electron-builder"
  },
  "dependencies": {
    "@englishclass/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "com.englishclass.desktop",
    "productName": "Offline English Learning",
    "files": ["dist/**/*", "src/**/*"],
    "directories": {
      "output": "release"
    }
  }
}
